#!/usr/bin/env python3
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
gi.require_version("Vte", "2.91")

from gi.repository import Gtk, Gdk, Vte, GLib
import subprocess, socket, threading, json, os, signal

# --- Configuration ---
WINDOW_WIDTH = 900
WINDOW_HEIGHT = 540
SERVICE_NAME = "fios-orchestrator"
SOCKET_PATH = "/tmp/friday_orchestrator.sock"
TMUX_SESSION = "friday_session"
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
CSS_PATH = os.path.join(SCRIPT_DIR, "style.css")

# Force application name for Wayland/X11 Window Managers
GLib.set_prgname("Friday")
GLib.set_application_name("Friday")

def load_css():
    if not os.path.exists(CSS_PATH):
        print(f"Error: {CSS_PATH} not found.")
        return
    provider = Gtk.CssProvider()
    try:
        provider.load_from_path(CSS_PATH)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )
        print("CSS loaded successfully.")
    except Exception as e:
        print(f"CSS Load Error: {e}")

class TmuxTerminal(Gtk.Box):
    def __init__(self):
        super().__init__()
        self.term = Vte.Terminal()
        rgba = Gdk.RGBA()
        rgba.parse("rgba(0,0,0,0.3)")
        self.term.set_color_background(rgba)
        self.pack_start(self.term, True, True, 0)

    def attach(self):
        self.term.spawn_async(
            Vte.PtyFlags.DEFAULT, None,
            ["tmux", "attach-session", "-t", TMUX_SESSION],
            [], GLib.SpawnFlags.DEFAULT, None, None, -1, None, None
        )

class ChatUI(Gtk.Box):
    def __init__(self, terminal):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        self.terminal = terminal
        self.sock = None
        self.service_active = False  # Track service state
        
        header = Gtk.Box(spacing=10)
        header.get_style_context().add_class("header")
        
        title = Gtk.Label(label="FRIDAY")
        title.get_style_context().add_class("title")
        
        self.status_dot = Gtk.Label(label="●")
        self.status_dot.get_style_context().add_class("status-dot")
        
        self.status_text = Gtk.Label(label="Checking...")
        
        self.service_btn = Gtk.Button(label="Start")
        self.service_btn.get_style_context().add_class("service-btn")
        self.service_btn.connect("clicked", self.toggle_orchestrator)
        
        header.pack_start(title, False, False, 10)
        header.pack_start(self.status_dot, False, False, 0)
        header.pack_start(self.status_text, True, True, 0)
        header.pack_end(self.service_btn, False, False, 10)

        self.chat_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        self.scroller = Gtk.ScrolledWindow()
        self.scroller.get_style_context().add_class("chat-scroller")
        self.scroller.add(self.chat_box)

        self.entry = Gtk.Entry()
        self.entry.set_placeholder_text("Type your message...")
        self.entry.connect("activate", self.on_send)

        self.pack_start(header, False, False, 0)
        self.pack_start(self.scroller, True, True, 0)
        self.pack_start(self.entry, False, False, 5)

        # Add welcome message
        self.add_system_message("New Conversation")
        GLib.timeout_add(1000, self.refresh_service_state)

    def add_system_message(self, text):
        """Add a centered system message"""
        row = Gtk.Box()
        row.set_halign(Gtk.Align.CENTER)
        label = Gtk.Label(label=text)
        label.get_style_context().add_class("system-message")
        label.set_margin_top(5)
        label.set_margin_bottom(5)
        row.pack_start(label, False, False, 0)
        self.chat_box.pack_start(row, False, False, 0)
        self.chat_box.show_all()

    def refresh_service_state(self):
        try:
            active = subprocess.check_output(["systemctl", "--user", "is-active", SERVICE_NAME]).decode().strip() == "active"
        except: 
            active = False

        self.service_active = active
        ctx = self.status_dot.get_style_context()
        ctx.remove_class("status-running")
        ctx.remove_class("status-stopped")

        if active:
            ctx.add_class("status-running")
            self.status_text.set_text("Running")
            self.service_btn.set_label("Stop")
            self.connect_socket()
            GLib.idle_add(self.terminal.attach)
            self.entry.set_sensitive(True)
        else:
            ctx.add_class("status-stopped")
            self.status_text.set_text("Stopped")
            self.service_btn.set_label("Start")
            self.entry.set_sensitive(False)
            if self.sock:
                try:
                    self.sock.close()
                except:
                    pass
                self.sock = None
        return True

    def toggle_orchestrator(self, _):
        subprocess.call(["systemctl", "--user", "stop" if self.service_active else "start", SERVICE_NAME])
        GLib.timeout_add(500, self.refresh_service_state)

    def connect_socket(self):
        if self.sock: 
            return
        try:
            self.sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            self.sock.connect(SOCKET_PATH)
            self.add_system_message("Connected to orchestrator")
            threading.Thread(target=self.listen_loop, daemon=True).start()
        except Exception as e:
            self.add_system_message(f"Failed to connect: {str(e)}")
            self.sock = None

    def listen_loop(self):
        while True:
            try:
                data = self.sock.recv(4096)
                if not data: 
                    break
                for line in data.decode().splitlines():
                    try:
                        msg = json.loads(line)
                        if "user" in msg:
                            GLib.idle_add(self.add_message, "friday", msg["user"])
                        elif "thinking" in msg:
                            # Optionally show thinking messages
                            pass
                        elif "error" in msg:
                            GLib.idle_add(self.add_system_message, f"Error: {msg['error']}")
                    except json.JSONDecodeError:
                        # Handle non-JSON responses (raw text)
                        if line.strip():
                            GLib.idle_add(self.add_message, "friday", line)
            except Exception as e:
                print(f"Socket error: {e}")
                break
        
        # Connection lost
        GLib.idle_add(self.add_system_message, "Disconnected from orchestrator")
        self.sock = None

    def add_message(self, role, text):
        """Add a message bubble (role can be 'user' or 'friday')"""
        row = Gtk.Box()
        align = Gtk.Box()
        align.set_halign(Gtk.Align.END if role == "user" else Gtk.Align.START)
        
        # Create bubble with sender label
        bubble_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        bubble_box.get_style_context().add_class("bubble")
        bubble_box.get_style_context().add_class(f"{role}-bubble")
        
        # Sender label
        sender = Gtk.Label()
        sender.set_markup(f"<b>{'You' if role == 'user' else 'FRIDAY'}</b>")
        sender.set_halign(Gtk.Align.START)
        sender.set_margin_start(8)
        sender.set_margin_top(6)
        sender.set_margin_bottom(2)
        bubble_box.pack_start(sender, False, False, 0)
        
        # Message text
        lbl = Gtk.Label(label=text)
        lbl.set_line_wrap(True)
        lbl.set_max_width_chars(50)
        lbl.set_xalign(0)
        lbl.set_margin_start(8)
        lbl.set_margin_end(8)
        lbl.set_margin_bottom(6)
        bubble_box.pack_start(lbl, False, False, 0)
        
        align.pack_start(bubble_box, False, False, 5)
        row.pack_start(align, True, True, 5)
        
        self.chat_box.pack_start(row, False, False, 2)
        self.chat_box.show_all()
        
        # Scroll to bottom
        def scroll():
            adj = self.scroller.get_vadjustment()
            if adj:
                adj.set_value(adj.get_upper() - adj.get_page_size())
        GLib.idle_add(scroll)

    def on_send(self, entry):
        text = entry.get_text().strip()
        if text and self.sock:
            self.add_message("user", text)
            try: 
                self.sock.sendall((text + "\n").encode())
            except Exception as e:
                self.add_system_message(f"Failed to send: {str(e)}")
                self.sock = None
            entry.set_text("")
        elif text and not self.sock:
            self.add_system_message("Orchestrator not connected. Start it first.")

class FridayWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="FRIDAY Assistant")
        # WM_CLASS must be Friday to match Hyprland rules
        self.set_wmclass("Friday", "Friday")
        self.set_name("friday-assistant")
        # CHANGE THIS: Use UTILITY instead of DIALOG
        self.set_type_hint(Gdk.WindowTypeHint.NORMAL)
        # Ensure it doesn't try to be a 'Modal'
        self.set_modal(False) 

        # ADD THESE THREE LINES:
        self.set_type_hint(Gdk.WindowTypeHint.UTILITY) # Tells Hyprland this is a HUD
        self.set_position(Gtk.WindowPosition.NONE)    # Stop GTK from choosing a spot
        self.set_gravity(Gdk.Gravity.NORTH)           # Tell GTK the "anchor" is the top
        self.set_default_size(WINDOW_WIDTH, WINDOW_HEIGHT)
        self.set_decorated(False)
        self.set_keep_above(True)


        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual: self.set_visual(visual)
        self.set_app_paintable(True)

        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        main_box.get_style_context().add_class("glass-panel")
        
        self.terminal = TmuxTerminal()
        self.chat = ChatUI(self.terminal)

        self.notebook = Gtk.Notebook()
        self.notebook.append_page(self.chat, Gtk.Label(label="Chat"))
        self.notebook.append_page(self.terminal, Gtk.Label(label="Terminal"))
        
        main_box.pack_start(self.notebook, True, True, 0)
        self.add(main_box)
        self.connect("destroy", Gtk.main_quit)
        self.connect("key-press-event", self.on_key_press)
        # Connect signal and show window
        self.connect("show", self.on_window_show)
        self.show_all()
 
    def on_window_show(self, widget):
        """Method outside __init__ to fix AttributeError"""
        self.chat.entry.grab_focus()
        
    def on_key_press(self, widget, event):
        # If you press Escape, the app shuts down completely
        if event.keyval == Gdk.KEY_Escape:
            Gtk.main_quit()

if __name__ == "__main__":

    
    # SINGLE INSTANCE GUARD
    try:
        # Create a lock socket
        lock_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        lock_socket.bind(("127.0.0.1", 65432))
