        # If already running, send a system notification instead of printing
        subprocess.Popen([
            "notify-send", 
            "-a", "FRIDAY", 
            "-i", "distributor-logo-android", # Or a custom icon path
            "FRIDAY is already active", 
            "Press Super+C to summon the Assistant."
        ])
        os._exit(0)

    load_css()
    FridayWindow()

    load_css()
    FridayWindow()
    try:
        Gtk.main()
    except KeyboardInterrupt:
        pass
    finally:
        os._exit(0)